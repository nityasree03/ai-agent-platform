# Copy this file to .env and fill in real values to enable live calls.
# With nothing set, the agent runs entirely on free, deterministic mocks.

# Real Claude Haiku calls. Leave unset to use the free MockLLMClient instead.
ANTHROPIC_API_KEY=

# Web search tool. Tavily has a free tier. Leave unset to use mock search results.
TAVILY_API_KEY=

# LangSmith tracing (Week 3). Free developer tier available at smith.langchain.com.
# Leave unset to skip tracing and rely on the local trace list only.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-agent-platform

# Force mock mode even if API keys above are set (handy for CI / demos).
AGENT_FORCE_MOCK=0
